{
  "name": "whiteboard-server",
  "version": "1.0.0",
  "description": "Backend server for the Real-time Collaborative Whiteboard. Manages user sessions, drawing data, and real-time synchronization via WebSockets. This service is an integral part of a larger interconnected microservice ecosystem, designed to work alongside systems like Task Management, Social Media, and E-commerce platforms.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "nodejs",
    "express",
    "websocket",
    "real-time",
    "collaboration",
    "whiteboard",
    "microservice",
    "authentication",
    "distributed-system"
  ],
  "author": "Your Organization/Team",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "winston": "^3.13.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
