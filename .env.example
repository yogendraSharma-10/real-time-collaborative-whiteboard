# Real-time Collaborative Whiteboard - Environment Variables Example

# Server Configuration
# These variables are used by the Node.js backend server.

# Port on which the Node.js server will listen.
PORT=5000

# Environment mode: 'development', 'production', 'test'.
# Affects logging, error handling, and performance optimizations.
NODE_ENV=development

# Secret key for signing JSON Web Tokens (JWTs).
# IMPORTANT: Use a strong, randomly generated key in production.
JWT_SECRET=your_super_secret_jwt_key_for_whiteboard_app_12345

# MongoDB connection URI.
# Used for storing user data, session information, or whiteboard state persistence.
# Example for a local MongoDB instance:
DB_URI=mongodb://localhost:27017/whiteboard_db

# Comma-separated list of allowed origins for Cross-Origin Resource Sharing (CORS).
# This specifies which client domains are permitted to make requests to the server.
# For development, typically includes the React development server.
CORS_ORIGIN=http://localhost:3000

# Path for WebSocket connections.
# If the WebSocket server runs on the same HTTP server, this defines the endpoint path.
WEBSOCKET_PATH=/websocket

# Session secret for Express sessions (if using cookie-based sessions).
# SESSION_SECRET=another_strong_secret_for_sessions

# Cross-Project Service Integrations (Server-side)
# These URLs are used by the whiteboard backend to communicate with other microservices.

# Base URL for the Micro Social Media Dashboard API.
# The whiteboard might interact with this service for user profiles, notifications, etc.
SOCIAL_MEDIA_SERVICE_API_URL=http://localhost:6000/api/social

# Base URL for the Multi-vendor E-commerce Marketplace API.
# The whiteboard might integrate with this for user authentication, billing, or shared resources.
ECOMMERCE_SERVICE_API_URL=http://localhost:7000/api/ecommerce


# Client Configuration (React App)
# These variables are exposed to the client-side React application.
# For Create React App, they MUST be prefixed with `REACT_APP_`.

# Base URL for the backend API endpoints (e.g., for REST API calls).
REACT_APP_API_BASE_URL=http://localhost:5000/api

# Full WebSocket URL for connecting to the real-time server.
# Use 'ws://' for development (HTTP) or 'wss://' for production (HTTPS).
REACT_APP_WEBSOCKET_URL=ws://localhost:5000

# Path for WebSocket connections, must match the server's WEBSOCKET_PATH.
REACT_APP_WEBSOCKET_PATH=/websocket

# Cross-Project Service Integrations (Client-side)
# These URLs are used by the whiteboard frontend to link to or interact with other microservice frontends.

# Frontend URL for the Micro Social Media Dashboard.
# Used for navigation or embedding components from the social media app.
REACT_APP_SOCIAL_MEDIA_DASHBOARD_FRONTEND_URL=http://localhost:6001

# Frontend URL for the Multi-vendor E-commerce Marketplace.
# Used for navigation or embedding components from the e-commerce app.
REACT_APP_ECOMMERCE_MARKETPLACE_FRONTEND_URL=http://localhost:7001