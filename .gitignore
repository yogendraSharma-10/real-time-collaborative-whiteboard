# Git Ignore for Real-time Collaborative Whiteboard

# Node.js
# node_modules
# This ignores the main node_modules directory if it exists at the root.
# In a monorepo setup, client/ and server/ will have their own.
node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# Environment variables
# We have .env.example, so .env should be ignored.
.env
.env.*.local
.env.local

# Dependency lock files (if not committed)
# yarn.lock
# pnpm-lock.yaml

# OS and Editor specific files
.DS_Store
.vscode/
.idea/
.history/
*.sublime-project
*.sublime-workspace
Thumbs.db
ehthumbs.db
.sass-cache/
.project
.classpath
.settings/

# Client-side (React) specific ignores
client/node_modules/
client/build/
client/.env
client/.env.*.local
client/.env.local
client/coverage/ # Jest coverage reports

# Server-side (Node.js) specific ignores
server/node_modules/
server/dist/ # If server code is transpiled or bundled
server/.env
server/.env.*.local
server/.env.local
server/coverage/ # Jest coverage reports

# Test reports
junit.xml
test-results.xml
coverage/

# IDE specific (e.g., WebStorm)
*.iml
.idea/
.project
.classpath
.settings/

# Docker
.dockerignore

# Other common build artifacts
*.tgz
*.zip
*.rar
*.7z
*.gz
*.tar
*.bak
*.swp
*.swo